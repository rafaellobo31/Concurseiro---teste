
# Google Gemini API Key (Obtain at aistudio.google.com)
# This key must be configured in Vercel Dashboard as API_KEY or GEMINI_API_KEY
API_KEY=your_gemini_api_key_here

# Supabase Configuration (Required for persistence)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Mercado Pago Configuration
MP_ACCESS_TOKEN=your-mp-access-token
APP_URL=https://your-app.vercel.app
MP_PLAN_PRICE=19.99
MP_CURRENCY=BRL
